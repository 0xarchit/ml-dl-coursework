# Git LFS tracking for large dataset and model files
# Run once locally: git lfs install

# Track whole datasets directory (if you store raw datasets here)
datasets/** filter=lfs diff=lfs merge=lfs -text

# Common archive formats
*.zip filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text

# Keras / HDF5 model files
*.h5 filter=lfs diff=lfs merge=lfs -text
*.hdf5 filter=lfs diff=lfs merge=lfs -text
*.keras filter=lfs diff=lfs merge=lfs -text

# Model outputs directory
outputs/** filter=lfs diff=lfs merge=lfs -text
